# Example batch file for `voxclone clone-batch`.
# Copy to voices.env, edit, then run:
#   voxclone clone-batch voices.env --i-have-consent
#
# Format: one block per voice, numbered VOICE<N>_*. N must be >= 1.
# Numbering may be sparse and out of order; entries run in ascending N order.
# Required keys per voice: NAME, URL, START, END.

VOICE1_NAME=alice
VOICE1_URL=https://youtu.be/REPLACE_ME
VOICE1_START=0:30
VOICE1_END=0:40

VOICE2_NAME=bob
VOICE2_URL=https://youtu.be/REPLACE_ME
VOICE2_START=1:00
VOICE2_END=1:10
